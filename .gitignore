# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
**/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env — never commit secrets; template-only file stays tracked
.env*
!.env.example

# Netlify local build output (do not commit)
.netlify/

# legacy / leftovers
/voice-app/

# Vercel CLI (if used)
.vercel

# Prisma local SQLite (only if you use a file DB under prisma/)
/prisma/*.db
/prisma/*.db-journal

# IDE (optional — remove lines if your team commits shared .vscode settings)
.idea
.vscode
