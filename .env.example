# OpenAI (Whisper STT + GPT-4o Summary)
OPENAI_API_KEY=sk-your-key-here
UHC_DEMO_FALLBACK=true

# NextAuth (Week 8 — Physician login)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Demo Mode (for Netlify without DB)
# When UHC_DEMO_MODE=true (or DATABASE_URL is missing):
# - Auth accepts demo credentials (no DB user required)
# - Patients/intakes store in-memory (not persisted between deploys)
# With Neon: set DATABASE_URL, set UHC_DEMO_MODE=false (or unset), keep NEXTAUTH_* set.
UHC_DEMO_MODE=false
UHC_DEMO_EMAIL=doctor@shuno.online
UHC_DEMO_PASSWORD=1234

# PostgreSQL (Week 8 — Patient & intake persistence)
# Local Homebrew: postgresql://YOUR_MAC_USERNAME@localhost:5432/uhc_voice
# Neon on Netlify (pooled host, e.g. *-pooler*):
#   1) In Netlify → Environment variables: add DATABASE_URL for Production + Branch deploys + Deploy previews.
#   2) Append &pgbouncer=true to the pooler URL (required for Prisma + Neon pooler). Example:
#      .../neondb?sslmode=require&pgbouncer=true
#   3) Set UHC_DEMO_MODE=false or delete the variable so the app uses Postgres (not in-memory).
#   4) After deploy, open https://YOUR_SITE.netlify.app/api/health/db — prisma should be "ok".
# Local Postgres: same URL without pgbouncer is fine.
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/uhc_voice


# Optional: override default seed password for first physician
# SEED_PASSWORD=your-secure-password
